# SupplyChainTracker - Centralized Configuration
# This file contains all configurable parameters for the project
# Use this as the single source of truth for program_id, keypairs, and environment settings

# ============================================================================
# Program Configuration
# ============================================================================
# Program ID derived from sc-solana/programs/sc-solana/src/lib.rs declare_id!()
# This is the CANONICAL program ID - all runbooks and tests should reference this
PROGRAM_ID=7xX49ydi4Sx6hJQjj26arXhLZgwZXpr5sNJAKb29aPaN

# Paths generated by `anchor build`
PROGRAM_KEYPAIR=./target/deploy/sc_solana-keypair.json
PROGRAM_SO=./target/deploy/sc_solana.so
PROGRAM_IDL=./target/idl/sc_solana.json

# ============================================================================
# Deployer/Admin Configuration
# ============================================================================
# Main admin/deployer wallet
DEPLOYER_KEYPAIR=~/.config/solana/id.json

# ============================================================================
# Role Wallets Configuration
# ============================================================================
# All role keypairs are stored in ./config/keypairs/
KEYPAIRS_DIR=./config/keypairs

FABRICANTE_KEYPAIR=${KEYPAIRS_DIR}/fabricante.json
AUDITOR_HW_KEYPAIR=${KEYPAIRS_DIR}/auditor_hw.json
TECNICO_SW_KEYPAIR=${KEYPAIRS_DIR}/tecnico_sw.json
ESCUELA_KEYPAIR=${KEYPAIRS_DIR}/escuela.json

# ============================================================================
# Test Configuration
# ============================================================================
# Airdrop amount in lamports (5 SOL)
AIRDROP_AMOUNT=5000000000

# Test netbook data
TEST_SERIAL_NUMBER=NB-2024-001
TEST_BATCH_ID=BATCH-001
TEST_MODEL_SPECS="Lenovo ThinkPad X1"
TEST_OS_VERSION="Ubuntu 22.04"

# ============================================================================
# Environment-Specific Overrides
# ============================================================================
# Load environment-specific config
# Usage: source config/config.env && source config/environments/localnet.env
