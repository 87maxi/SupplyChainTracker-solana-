// Addon configuration for Solana/SVM
addon "svm" {
  network_id = "localnet"
  rpc_api_url = "http://localhost:8899"
}

// Validate software on a netbook
// State transition: HwAprobado (1) -> SwValidado (2)
// Usage: surfpool run validate-software --env localnet --browser -f
//
// Prerequisites:
//   - Source config: source config/config.env && source runbooks/environments/localnet.env
//   - Netbook must pass hardware audit (HwAprobado state)
//
// Inputs:
//   - tecnico_keypair: Path to technician keypair (default: env.TECNICO_SW_KEYPAIR)
//   - serial_number: Serial number of the netbook
//   - os_version: OS version installed

// Signers
signer "tecnico" "svm::web_wallet" {
  description = "Software technician account (must have TECNICO_SW role)"
  keypair_path = env.TECNICO_SW_KEYPAIR
}

// Program artifacts from Anchor project
variable "program" {
  description = "Program artifacts (IDL, binary, keypair, program_id)"
  value = svm::get_program_from_anchor_project("sc_solana")
}

variable "program_id" {
  description = "Deployed program ID"
  value = variable.program.program_id
}

// Inputs
variable "serial_number" {
  description = "Serial number of the netbook"
  value = env.NETBOOK_SERIAL
}

variable "os_version" {
  description = "OS version installed"
  value = env.NETBOOK_OS_VERSION
}

variable "passed" {
  description = "Whether the software validation passed"
  value = true
}

// PDA derivation - svm::find_pda(program_id, seeds) returns {pda, bump_seed}
variable "config_pda" {
  description = "Config account PDA"
  value = svm::find_pda(variable.program_id, ["config"])
}

variable "netbook_pda" {
  description = "Netbook account PDA"
  value = svm::find_pda(variable.program_id, ["netbook", variable.serial_number])
}

// Validate action
action "validate" "svm::process_instructions" {
  description = "Validate software installation on netbook"
  instruction {
    program_idl = variable.program.idl
    instruction_name = "validate_software"
    instruction_args = [
      variable.serial_number,
      variable.os_version,
      variable.passed
    ]
    accounts = [
      {
        public_key = variable.netbook_pda.pda
        writable = true
        signer = false
      },
      {
        public_key = variable.config_pda.pda
        writable = false
        signer = false
      },
      {
        public_key = signer.tecnico.public_key
        writable = true
        signer = true
      },
      {
        public_key = svm::system_program_id()
        writable = false
        signer = false
      }
    ]
  }
  signers = [signer.tecnico]
}

// Outputs
output "validation_signature" {
  description = "Validation transaction signature"
  value = action.validate.signatures | first()
}

output "new_state" {
  description = "New netbook state after validation"
  value = "SwValidado"
}
