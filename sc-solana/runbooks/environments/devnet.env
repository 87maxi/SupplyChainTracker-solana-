# Devnet Configuration
# Loaded by: source config/config.env && source runbooks/environments/devnet.env

network_id=devnet
rpc_api_url=https://api.devnet.solana.com
ws_url=wss://api.devnet.solana.com

# Program ID - override with actual deployed ID
PROGRAM_ID=${PROGRAM_ID:-7xX49ydi4Sx6hJQjj26arXhLZgwZXpr5sNJAKb29aPaN}

# Deployer wallet
DEPLOYER_KEYPAIR=${DEPLOYER_KEYPAIR:-~/.config/solana/id.json}

# Role keypairs
KEYPAIRS_DIR=${KEYPAIRS_DIR:-./config/keypairs}
FABRICANTE_KEYPAIR=${FABRICANTE_KEYPAIR:-${KEYPAIRS_DIR}/fabricante.json}
AUDITOR_HW_KEYPAIR=${AUDITOR_HW_KEYPAIR:-${KEYPAIRS_DIR}/auditor_hw.json}
TECNICO_SW_KEYPAIR=${TECNICO_SW_KEYPAIR:-${KEYPAIRS_DIR}/tecnico_sw.json}
ESCUELA_KEYPAIR=${ESCUELA_KEYPAIR:-${KEYPAIRS_DIR}/escuela.json}

# Netbook test data
NETBOOK_SERIAL=${NETBOOK_SERIAL:-NB-2024-001}
NETBOOK_BATCH=${NETBOOK_BATCH:-BATCH-001}
NETBOOK_MODEL=${NETBOOK_MODEL:-"Lenovo ThinkPad X1"}
NETBOOK_OS_VERSION=${NETBOOK_OS_VERSION:-"Ubuntu 22.04"}
NETBOOK_SERIALS=${NETBOOK_SERIALS:-"NB-2024-001,NB-2024-002,NB-2024-003"}
NETBOOK_BATCHES=${NETBOOK_BATCHES:-"BATCH-001,BATCH-001,BATCH-001"}
NETBOOK_MODELS=${NETBOOK_MODELS:-"Lenovo X1,Lenovo X1,Lenovo X1"}
ROLE_TO_REQUEST=${ROLE_TO_REQUEST:-FABRICANTE}
ROLE_TO_REVOKE=${ROLE_TO_REVOKE:-FABRICANTE}
ROLE_TO_GRANT=${ROLE_TO_GRANT:-FABRICANTE}
ROLE_TO_REMOVE=${ROLE_TO_REMOVE:-FABRICANTE}
ROLE_TO_QUERY=${ROLE_TO_QUERY:-FABRICANTE}
REQUESTER_KEYPAIR=${REQUESTER_KEYPAIR:-${KEYPAIRS_DIR}/fabricante.json}
NEW_HOLDER_KEYPAIR=${NEW_HOLDER_KEYPAIR:-${KEYPAIRS_DIR}/fabricante.json}
HOLDER_KEYPAIR=${HOLDER_KEYPAIR:-${KEYPAIRS_DIR}/fabricante.json}
ACCOUNT_TO_REVOKE_KEYPAIR=${ACCOUNT_TO_REVOKE_KEYPAIR:-${KEYPAIRS_DIR}/fabricante.json}
REQUESTER_ADDRESS=${REQUESTER_ADDRESS:-}
