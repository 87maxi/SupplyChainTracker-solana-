// Validate software on a netbook
// State transition: HwAprobado (1) -> SwValidado (2)
// Usage: surfpool run validate-software --env localnet --browser -f

// Signers
signer "tecnico" "svm::web_wallet" {
  description = "Software technician account (must have TECNICO_SW role)"
  keypair_path = input.tecnico_keypair
}

// Program reference
variable "program_id" {
  description = "Deployed program ID"
  value = "7xX49ydi4Sx6hJQjj26arXhLZgwZXpr5sNJAKb29aPaN"
}

variable "idl" {
  description = "Program IDL data"
  value = svm::get_idl_from_path("./target/idl/sc_solana.json")
}

// Inputs
variable "serial_number" {
  description = "Serial number of the netbook"
  value = input.serial_number
}

variable "os_version" {
  description = "OS version installed"
  value = input.os_version
}

variable "passed" {
  description = "Whether the software validation passed"
  value = true
}

// PDA derivation
variable "config_pda" {
  description = "Config account PDA"
  value = svm::find_pda(["config"], variable.program_id)
}

variable "netbook_pda" {
  description = "Netbook account PDA"
  value = svm::find_pda(["netbook", variable.serial_number], variable.program_id)
}

// Validate action
action "validate" "svm::process_instructions" {
  description = "Validate software installation on netbook"
  instruction {
    program_idl = variable.idl
    instruction_name = "validate_software"
    instruction_args = [
      variable.serial_number,
      variable.os_version,
      variable.passed
    ]
    accounts = [
      {
        public_key = variable.netbook_pda[0]
        writable = true
        signer = false
      },
      {
        public_key = variable.config_pda[0]
        writable = false
        signer = false
      },
      {
        public_key = signer.tecnico.public_key
        writable = true
        signer = true
      },
      {
        public_key = svm::system_program_id()
        writable = false
        signer = false
      }
    ]
  }
  signers = [signer.tecnico]
}

// Outputs
output "validation_signature" {
  description = "Validation transaction signature"
  value = action.validate.signatures[0]
}

output "new_state" {
  description = "New netbook state after validation"
  value = "SwValidado"
}
